#include <stdio.h>
#include <stdarg.h>
#include "variadic_functions.h"
/**
 *
 */
void print_numbers(const char *separator, const unsigned int n, ...)
{
	if (n == NULL)
		return;
	va_list ptr;
	unsigned int i;

	va_start (ptr, n);
	for (i = 0; i < n; i++)
		printf("%d%c ", va_arg (ptr, int), separator);
	printf("\n");

	va_end (ptr);
}	
